<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dt.student.register.mapper.primary.user.ModuleTypeMapper">

    <sql id="BASE_COLUMN_LIST">
        *, name AS nameOther
    </sql>

    <sql id="BASE_FROM">
        FROM module_types
    </sql>

    <sql id="BASE_WHERE">
        WHERE status = 1
        <if test="searchText != null">AND name LIKE CONCAT("%", #{searchText}, "%")</if>
    </sql>

    <select id="getList" parameterType="com.dt.student.register.model.base.filter.ModuleTypeFilter">
        SELECT
        <include refid="BASE_COLUMN_LIST"/>
        <include refid="BASE_FROM"/>
        <include refid="BASE_WHERE"/>
        ORDER BY
        <choose>
            <when test="orderBy != null">
                ${orderBy}
            </when>
            <otherwise>
                ordering ASC
            </otherwise>
        </choose>
        <if test="page != null and rowsPerPage != null">LIMIT #{page}, #{rowsPerPage}</if>
    </select>

    <select id="countList" parameterType="com.dt.student.register.model.base.filter.Filter" resultType="java.lang.Long">
        SELECT COUNT(id)
        <include refid="BASE_FROM"/>
        <include refid="BASE_WHERE"/>
    </select>

    <select id="getOne" parameterType="java.lang.Long" >
        SELECT *
        FROM module_types
        WHERE status = 1 AND id = #{id}
    </select>



</mapper>